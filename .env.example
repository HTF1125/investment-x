# =============================================================================
# Investment-X Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Database ---
DB_URL=postgresql://user:password@localhost:5432/investmentx
DB_NAME=investmentx

# --- Authentication ---
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
COOKIE_SECURE=false

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Debug ---
DEBUG_MODE=false

# --- AI Providers ---
GEMINI_API_KEY=
MINIMAX_API_KEY=

# --- Cloudflare R2 Object Storage ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Telegram ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# --- Email ---
EMAIL_LOGIN=
EMAIL_PASSWORD=
EMAIL_RECIPIENTS=[]

# --- Google Drive ---
GOOGLE_DRIVE_FOLDER_ID=
